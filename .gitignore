# =============================================================
# .gitignore — FullStackAttack Producto 4
# =============================================================

# Dependencias Node.js
node_modules/
**/node_modules/

# Variables de entorno privadas
.env
.env.*
**/.env
**/.env.*

# Permitimos solo archivos de ejemplo públicos
!.env.example
!**/.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Builds, distribución y cachés
dist/
build/
.cache/
.parcel-cache/
coverage/

# Sistema operativo
.DS_Store
Thumbs.db
Desktop.ini

# IntelliJ / JetBrains
.idea/
*.iml

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Datos locales de MongoDB
mongo-data/
mongodb-data/
data/db/

# Archivos temporales
*.bak
*.tmp
*.swp
*.swo

# Copias de seguridad
*.backup
*.old

# Archivos comprimidos temporales
*.zip
*.rar
*.7z