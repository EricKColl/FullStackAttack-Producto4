# =============================================================
# .env.example — Plantilla de variables de entorno
# -------------------------------------------------------------
# Copia este archivo como ".env" y rellena los valores reales.
# El .env NO se sube al repositorio (está en .gitignore).
# =============================================================

# --- Servidor Express / Apollo ---
# Puerto en el que escucha la API GraphQL.
PORT=4000

# Entorno de ejecución: "development" activa logs detallados y Apollo Sandbox.
NODE_ENV=development

# --- MongoDB ---
# URI de conexión a MongoDB.
# - Docker local: mongodb://admin:admin@localhost:27017
# - MongoDB Atlas: mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net
MONGO_URI=mongodb://admin:admin@localhost:27017

# Nombre de la base de datos que usa la aplicación.
MONGO_DB_NAME=jobconnect_producto4

# --- Autenticación admin (JWT) ---
# Secreto usado para firmar los JSON Web Tokens.
# En producción debe ser una cadena aleatoria larga (≥ 32 caracteres).
JWT_SECRET=cambia-esta-cadena-por-algo-largo-y-aleatorio

# Tiempo de validez del token (formato de la librería "ms": 1h, 12h, 7d, etc.).
JWT_EXPIRES_IN=12h

# --- Credenciales del administrador por defecto ---
# Usadas por el script de seed para crear el usuario admin inicial.
ADMIN_EMAIL=admin@jobconnect.com
ADMIN_PASSWORD=admin1234