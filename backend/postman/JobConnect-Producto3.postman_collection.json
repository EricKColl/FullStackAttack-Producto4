    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Script post-response del Login Admin.\r",
                  "// Extrae el token de la respuesta y lo guarda en la variable de entorno\r",
                  "// {{token}} para que el resto de requests protegidas puedan usarlo\r",
                  "// automáticamente en su header Authorization.\r",
                  "\r",
                  "const responseJson = pm.response.json();\r",
                  "\r",
                  "// Caso 1: el login ha sido exitoso → guardamos el token.\r",
                  "if (responseJson?.data?.loginAdmin?.token) {\r",
                  "    const token = responseJson.data.loginAdmin.token;\r",
                  "    pm.environment.set(\"token\", token);\r",
                  "    console.log(\"Token guardado correctamente en la variable {{token}}.\");\r",
                  "}\r",
                  "\r",
                  "// Caso 2: el servidor devolvió errors → mostramos un mensaje claro.\r",
                  "if (responseJson?.errors?.length > 0) {\r",
                  "    const primerError = responseJson.errors[0];\r",
                  "    console.warn(\"Error en loginAdmin:\", primerError.message);\r",
                  "}\r",
                  "\r",
                  "// Tests automáticos para verificar el comportamiento esperado.\r",
                  "pm.test(\"Status code es 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"La respuesta contiene un token\", () => {\r",
                  "    pm.expect(responseJson?.data?.loginAdmin?.token).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"El usuario devuelto tiene rol admin\", () => {\r",
                  "    pm.expect(responseJson?.data?.loginAdmin?.usuario?.rol).to.eql(\"admin\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"query\": \"mutation LoginAdmin($email: String!, $password: String!) { loginAdmin(email: $email, password: $password) { token usuario { id email rol } } }\",\r\n  \"variables\": {\r\n    \"email\": \"{{adminEmail}}\",\r\n    \"password\": \"{{adminPassword}}\"\r\n  }\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}",
              "host": [
                "{{baseUrl}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
