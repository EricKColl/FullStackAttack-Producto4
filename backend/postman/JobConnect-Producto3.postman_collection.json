          "name": "5.1. Mutación SIN token (debe dar 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Tests negativos: el éxito del test es que la operación FALLE.\r",
                  "// Si esta publicación se llegara a crear, la seguridad estaría rota.\r",
                  "\r",
                  "const json = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code es 200 (GraphQL siempre responde 200, los errores van en el body)\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"La respuesta contiene un bloque 'errors'\", () => {\r",
                  "    pm.expect(json.errors).to.be.an(\"array\");\r",
                  "    pm.expect(json.errors.length).to.be.greaterThan(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"El error es UNAUTHORIZED (no autenticado)\", () => {\r",
                  "    const primerError = json.errors[0];\r",
                  "    const codigo = primerError.extensions?.code;\r",
                  "    pm.expect(codigo).to.eql(\"UNAUTHORIZED\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"La operación NO se ha ejecutado (data es null o crearPublicacion no existe)\", () => {\r",
                  "    const seEjecuto = json.data && json.data.crearPublicacion;\r",
                  "    pm.expect(seEjecuto).to.be.oneOf([null, undefined]);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"El mensaje del error indica que falta el token JWT\", () => {\r",
                  "    const mensaje = json.errors[0].message.toLowerCase();\r",
                  "    pm.expect(mensaje).to.include(\"token\");\r",
                  "});"
